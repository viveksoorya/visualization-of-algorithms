	\caption{Comparison of visualization techniques for Quantum Fourier Transform:
	(a) Bloch sphere captures only single-qubit phase $\phi$, failing to represent multi-qubit phase relationships;
	(b) State City density matrix reveals periodic phase patterns in imaginary components;
	(c) Circuit diagram showing characteristic butterfly pattern of QFT;
	(d) Cost landscape for QFT parameter optimization.}
	\label{fig:qft_comparison}
\end{figure}

\textbf{Key Findings:}

\begin{itemize}
	\item \textbf{Bloch Sphere} fails for multi-qubit phase relationships (only shows single-qubit phase)
	\item \textbf{State City} reveals periodic phase patterns in the imaginary part
	\item State City is \textbf{essential} for understanding QFT behavior
\end{itemize}

